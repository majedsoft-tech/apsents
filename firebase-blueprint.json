{
  "entities": {
    "Grade": {
      "title": "Grade",
      "description": "A school grade level",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "Class": {
      "title": "Class",
      "description": "A class within a grade",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "gradeId": { "type": "string" }
      },
      "required": ["name", "gradeId"]
    },
    "Teacher": {
      "title": "Teacher",
      "description": "A school teacher",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "Student": {
      "title": "Student",
      "description": "A school student",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "gradeId": { "type": "string" },
        "classId": { "type": "string" }
      },
      "required": ["name", "gradeId", "classId"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "An attendance record",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "period": { "type": "string" },
        "gradeId": { "type": "string" },
        "classId": { "type": "string" },
        "teacherId": { "type": "string" },
        "present": { "type": "array" },
        "absent": { "type": "array" },
        "isNoAbsence": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "period", "gradeId", "classId", "present", "absent"]
    },
    "Behavior": {
      "title": "Behavior",
      "description": "A student behavior incident",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "date": { "type": "string" },
        "period": { "type": "string" },
        "teacherId": { "type": "string" },
        "teacherName": { "type": "string" },
        "violation": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "date", "period", "violation"]
    }
  },
  "firestore": {
    "grades/{gradeId}": {
      "schema": "Grade",
      "description": "Collection of school grades"
    },
    "classes/{classId}": {
      "schema": "Class",
      "description": "Collection of school classes"
    },
    "teachers/{teacherId}": {
      "schema": "Teacher",
      "description": "Collection of school teachers"
    },
    "students/{studentId}": {
      "schema": "Student",
      "description": "Collection of students"
    },
    "attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Collection of attendance records"
    },
    "behaviors/{behaviorId}": {
      "schema": "Behavior",
      "description": "Collection of student behavior records"
    }
  }
}
