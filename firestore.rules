rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global catch-all default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(data) {
      return data != null && data.userId == request.auth.uid;
    }

    match /grades/{gradeId} {
      allow read, delete: if isSignedIn() && isOwner(resource.data);
      allow create: if isSignedIn() && isOwner(request.resource.data);
      allow update: if isSignedIn() && isOwner(resource.data) && isOwner(request.resource.data);
    }

    match /classes/{classId} {
      allow read, delete: if isSignedIn() && isOwner(resource.data);
      allow create: if isSignedIn() && isOwner(request.resource.data);
      allow update: if isSignedIn() && isOwner(resource.data) && isOwner(request.resource.data);
    }

    match /teachers/{teacherId} {
      allow read, delete: if isSignedIn() && isOwner(resource.data);
      allow create: if isSignedIn() && isOwner(request.resource.data);
      allow update: if isSignedIn() && isOwner(resource.data) && isOwner(request.resource.data);
    }

    match /students/{studentId} {
      allow read, delete: if isSignedIn() && isOwner(resource.data);
      allow create: if isSignedIn() && isOwner(request.resource.data);
      allow update: if isSignedIn() && isOwner(resource.data) && isOwner(request.resource.data);
    }

    match /attendance/{attendanceId} {
      allow read, delete: if isSignedIn() && isOwner(resource.data);
      allow create: if isSignedIn() && isOwner(request.resource.data);
      allow update: if isSignedIn() && isOwner(resource.data) && isOwner(request.resource.data);
    }

    match /behaviors/{behaviorId} {
      allow read, delete: if isSignedIn() && isOwner(resource.data);
      allow create: if isSignedIn() && isOwner(request.resource.data);
      allow update: if isSignedIn() && isOwner(resource.data) && isOwner(request.resource.data);
    }
  }
}
